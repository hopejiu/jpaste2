{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "webview-opener",
  "description": "Allow external quicklaunch webview windows to open links (window.open / target=_blank) via the OS default handler",
  "windows": ["webview-*"],
  "remote": {
    "urls": ["https://*", "http://*"]
  },
  "permissions": [
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" },
        { "url": "mailto:*" },
        { "url": "tel:*" }
      ]
    }
  ]
}
