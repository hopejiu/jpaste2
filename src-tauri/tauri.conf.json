{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jPaste",
  "version": "0.1.0",
  "identifier": "jpaste2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "jPaste",
        "width": 700,
        "minWidth": 360,
        "height": 560,
        "minHeight": 300,
        "resizable": true,
        "decorations": false,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "**/*"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}